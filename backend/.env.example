OPENAI_API_KEY=your_openai_api_key
# Fallback for every agent when its dedicated setting is not supplied.
OPENAI_MODEL=gpt-5.6-terra
# Terra balances quality and cost for the core planning and content-generation work.
PLANNER_MODEL=gpt-5.6-terra
DESIGNER_MODEL=gpt-5.6-terra
ASSESSMENT_MODEL=gpt-5.6-terra
# Terra generates concrete print-ready classroom sheets.
MATERIALS_MODEL=gpt-5.6-terra
# Luna is a lower-cost choice for the lighter consistency-review task.
REVIEWER_MODEL=gpt-5.6-luna
# Optional demo mode: serves bundled fixtures and never calls the OpenAI API.
CLARA_MOCK_MODE=false
FRONTEND_ORIGIN=http://localhost:5173
# Optional student section (Supabase). The service-role key remains backend-only
# and is used only after FastAPI verifies the user's Supabase JWT.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_public_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_server_only_service_role_key
# Optional when your project uses a custom Auth issuer.
# SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
